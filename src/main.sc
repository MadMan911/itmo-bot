require: slotfilling/slotFilling.sc
  module = sys.zb-common

theme: /

    state: /hello
        q!: (привет|здравствуй*|добрый день|добрый вечер|доброе утро|hi|hello|старт|start|начало|начать|запуск|помощь|help)
        a: Привет! Я бот-помощник. Могу рассказать о погоде и курсах валют.

    state: /weather
        q!: (погода|прогноз|температура|weather|forecast|как погода|какая погода|дождь|осадки|зонт|тепло|холодно|климат|синоптик|облачно|ветер|влажность)
        a: Сегодня температура +15C, облачность переменная, осадки не ожидаются.

    state: /currency
        q!: (курс|валюта|валюты|доллар|евро|рубль|юань|фунт|обмен|currency|exchange|деньги|USD|EUR|RUB|стоимость валюты|курс валют|обменный курс)
        a: Актуальные курсы: USD — 90.5 руб., EUR — 98.3 руб., CNY — 12.4 руб.

    state: /NoMatch
        event!: noMatch
        a: Извините, не понял запрос. Я могу рассказать о погоде или курсах валют.